# Production env vars for GitHub Pages build
# These are read at build time by Vite.

# Render backend API base URL
VITE_API_BASE_URL=https://art-connect-c0ak.onrender.com/api/v1

# GitHub Pages base path
# If repo is `hunarhub`, keep /hunarhub/
# If repo is `art-connect`, use /art-connect/
VITE_BASE_PATH=/hunarhub/

